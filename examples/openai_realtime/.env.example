OPENAI_API_KEY=
THYMIA_API_KEY=

LOG_LEVEL=INFO

# Set to "false" if you're playing the agent through laptop or external speakers.
# Without acoustic echo cancellation (AEC), the agent's own voice leaks into the
# mic and triggers a self-interruption loop. Half-duplex prevents that by muting
# the mic while the agent is talking. Headphones/AirPods → leave as "true".
ALLOW_INTERRUPTION=true

# Optional Sentinel profile fields. If left blank the agent will prompt you for
# them on each run (press Enter at the prompt to skip — Sentinel will impute
# them from voice, less accurate). Setting them here bypasses the prompts.
THYMIA_DOB=
THYMIA_BIRTH_SEX=
